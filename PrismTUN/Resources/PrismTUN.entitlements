<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Outbound network connections (to proxy servers) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Local listener (mixed proxy inbound) -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- Needed to run embedded sing-box binary -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Phase 2: TUN mode — requires Apple Developer account -->
    <!-- <key>com.apple.developer.networking.networkextension.packet-tunnel</key> -->
    <!-- <true/> -->
</dict>
</plist>
